# PROJECTNAME Configuration
# Copy to .env and adjust values

# Application
APP_NAME=PROJECTNAME
APP_USER=deploy
APP_PORT=8080
APP_ENV=production

# Services (space-separated systemd unit names)
# Falls back to APP_NAME if not set
# APP_SERVICES=""

# SSH key import — GitHub username whose public keys get added to APP_USER
SSH_GITHUB_USER=vanhecke

# Logging
LOG_LEVEL=INFO
# LOG_FILE=/var/log/PROJECTNAME/deploy.log

# Firewall
FIREWALL_ENABLED=true
ALLOWED_PORTS="22 80 443"

# System hardening
# SWAP_SIZE=2G
# APP_HOSTNAME=

# Directories (auto-created by deploy)
# APP_DATA_DIR=/var/lib/PROJECTNAME

# Backups
BACKUP_KEEP=5

# Packages (space-separated extra packages to install)
EXTRA_PACKAGES=""
