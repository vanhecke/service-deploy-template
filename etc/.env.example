# PROJECTNAME Configuration
# Copy to .env and adjust values

# Application
APP_NAME=PROJECTNAME
APP_USER=deploy
APP_PORT=8080
APP_ENV=production

# SSH key import — GitHub username whose public keys get added to APP_USER
SSH_GITHUB_USER=vanhecke

# Logging
LOG_LEVEL=INFO
# LOG_FILE=/var/log/PROJECTNAME/deploy.log

# Firewall
FIREWALL_ENABLED=true
ALLOWED_PORTS="22 80 443"

# Packages (space-separated extra packages to install)
EXTRA_PACKAGES=""
